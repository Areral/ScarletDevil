# Runtime data / IPC files (Python <-> Go JSON handoff).
# NOTE: must ignore the directory *contents* (data/*), not the directory
# itself (data/) — git cannot re-include a file with `!data/foo.json` when the
# parent `data/` dir is excluded, so the whitelist below would silently fail
# and `git add data/pool.json` errors out with exit 1 in the merge job.
data/*
!data/source_health.json
!data/pool.json
!data/history.json

# Go core build artifacts
go_core/angra_core
go_core/angra_core.exe

# Logs
*.log

# Python bytecode
__pycache__/
*.pyc

# Ralph harness scratch
.last-branch

# Ralph harness infrastructure (kept on disk, not tracked)
ralph.sh
ralph.prompt.md

# Archived runs
archive/

# Local redesign prototypes / scratch (not part of the published site)
redesign/

# Claude Code tooling config (local, not part of the site)
.claude/
